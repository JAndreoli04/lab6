<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab 6: Quote Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>

    <%- include("partials/header.ejs") %>
    <form id="searchByKeywordForm" action="/searchByKeyword" method="GET">
        Keyword: <input type="text" name="Keyword">
        <button>Search by Keyword</button>
    </form>
    <br>
    <form action="/searchByAuthor" method="GET">
        Author: 
        <select>
            <% for(let i of authors) { %>
                <option value="<%=i.authorId %>"><%=i.firstName%> <%=i.lastName%></option>
            <%}%>
        </select>
    </form>
    <br>
    <%- include("partials/footer.ejs") %>

    <script>
        document.querySelector("#searchByKeywordForm").addEventListener("submit", validateKeyword);

        function validateKeyword(){
            let keyword = document.querySelector("input[name = Keyword]").value;
            if(keyword.length < 3){
                alert("Keyword must be at least 3 characters");
                event.preventDefault(); //prevents the form submission
            }
        }
    </script>
</body>

</html>